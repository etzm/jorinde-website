---
import BrandMark from "../components/BrandMark.astro";

interface Props {
	title: string;
	description?: string;
	activeNav?: "workshops" | "projekte" | "mir" | "kontakt" | null;
}
const { title, description = "GardenGeoDome — Workshops zum Bauen geodätischer Kuppeln in Freiburg.", activeNav = null } = Astro.props;

// All internal links use BASE_URL so deploys at any subpath (e.g. /jorinde-website) work.
const root = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
	{ label: "Workshops", href: `${root}/#workshops`, key: "workshops" },
	{ label: "Projekte", href: `${root}/projekte`, key: "projekte" },
	{ label: "Über mich", href: `${root}/zu-mir`, key: "mir" },
	{ label: "Kontakt", href: `${root}/kontakt`, key: "kontakt" },
];
---
<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${root}/favicon.svg`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<style is:global>
			:root {
				--bg: #eef1e6;
				--ink: #1a1a1a;
				--green-deep: #2d4a2b;
				--green: #4f6b47;
				--green-soft: #6e8867;
				--wood: #a88860;
				--line: #1a1a1a;
				--muted: #6b6b6b;
				--surface: #f5f7ee;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html, body {
				background: var(--bg);
				color: var(--ink);
				font-family: "Manrope", system-ui, sans-serif;
				line-height: 1.5;
				-webkit-font-smoothing: antialiased;
			}
			a { color: inherit; text-decoration: none; }
			img { max-width: 100%; display: block; }
			h1, h2, h3, h4 { letter-spacing: -0.02em; line-height: 1.1; font-weight: 300; }
			h1 strong, h2 strong, h3 strong { font-weight: 700; }
			p { color: var(--ink); }

			/* NAV */
			.nav {
				display: flex; justify-content: space-between; align-items: center;
				padding: 1.5rem 3rem;
				border-bottom: 1px solid var(--line);
			}
			.brand {
				font-weight: 700; letter-spacing: -0.02em; font-size: 1rem;
				display: flex; align-items: center; gap: 0.7rem;
				color: var(--green-deep);
			}
			.brand .wordmark { color: var(--ink); }
			.brandmark-svg { display: block; }
			.nav ul { display: flex; gap: 2rem; list-style: none; font-size: 0.85rem; font-weight: 500; }
			.nav ul a { transition: color 150ms; padding-bottom: 2px; border-bottom: 1px solid transparent; }
			.nav ul a:hover { color: var(--green-deep); }
			.nav ul a.active { color: var(--green-deep); border-bottom-color: var(--green-deep); }

			/* BUTTONS */
			.btn {
				display: inline-block;
				padding: 0.85rem 1.4rem; font-size: 0.9rem; font-weight: 600;
				border: 1px solid var(--ink); background: transparent; color: var(--ink);
				cursor: pointer;
				transition: background 150ms, color 150ms, border-color 150ms;
			}
			.btn:hover { background: var(--ink); color: var(--bg); }
			.btn.primary { background: var(--green-deep); color: var(--bg); border-color: var(--green-deep); }
			.btn.primary:hover { background: var(--ink); border-color: var(--ink); }

			/* TYPOGRAPHIC HELPERS */
			.kicker {
				font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
				color: var(--green-deep); font-weight: 600; margin-bottom: 1.5rem;
				display: inline-flex; align-items: center; gap: 0.5rem;
			}
			.kicker::before { content: ""; width: 22px; height: 1px; background: var(--green-deep); }

			/* FOOTER */
			.foot {
				padding: 3rem; display: flex; justify-content: space-between; align-items: center;
				font-size: 0.85rem;
				border-top: 1px solid var(--line);
			}
			.foot .left { display: flex; align-items: center; gap: 0.6rem; color: var(--green-deep); }
			.foot .left .footer-text { color: var(--ink); }
			.foot a:hover { color: var(--green-deep); }
			.foot-links { display: flex; gap: 1.5rem; }

			/* SHARED PAGE-HEADER for inner pages */
			.page-header {
				padding: 5rem 3rem 3rem;
				max-width: 980px;
			}
			.page-header h1 {
				font-size: clamp(2.25rem, 5vw, 4rem);
				font-weight: 300; letter-spacing: -0.035em;
				margin-bottom: 1rem; line-height: 1.05;
			}
			.page-header h1 strong { font-weight: 700; }
			.page-header .lede {
				font-size: 1.15rem; color: var(--muted); max-width: 36em;
				font-weight: 400;
			}

			/* RESPONSIVE BASE */
			@media (max-width: 760px) {
				.nav { padding: 1rem 1.5rem; flex-wrap: wrap; gap: 1rem; }
				.nav ul { gap: 1rem; flex-wrap: wrap; }
				.foot { padding: 2rem 1.5rem; flex-direction: column; gap: 1rem; align-items: flex-start; }
				.page-header { padding: 3rem 1.5rem 2rem; }
			}
		</style>
	</head>
	<body>
		<nav class="nav">
			<a class="brand" href={`${root}/`}>
				<BrandMark size={28} />
				<span class="wordmark">GardenGeoDome</span>
			</a>
			<ul>
				{nav.map((n) => (
					<li><a href={n.href} class={activeNav === n.key ? "active" : ""}>{n.label}</a></li>
				))}
			</ul>
		</nav>

		<slot />

		<footer class="foot">
			<div class="left">
				<BrandMark size={20} />
				<span class="footer-text">GardenGeoDome · Freiburg i.Br.</span>
			</div>
			<div class="foot-links">
				<a href={`${root}/impressum`}>Impressum</a>
				<a href={`${root}/datenschutz`}>Datenschutz</a>
				<a href={`${root}/kontakt`}>Kontakt</a>
			</div>
		</footer>
	</body>
</html>
