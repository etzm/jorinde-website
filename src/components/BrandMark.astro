---
interface Props {
	size?: number;
	stroke?: number;
}
const { size = 28, stroke = 1.2 } = Astro.props;
---
<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 28 20"
	width={size}
	height={(size * 20) / 28}
	fill="none"
	stroke="currentColor"
	stroke-width={stroke}
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="brandmark-svg"
>
	<!-- Faceted hemispheric dome silhouette (no sharp apex — flat top represents apex pentagon) -->
	<path d="M 2 15 L 4 11 L 8 7 L 14 5 L 20 7 L 24 11 L 26 15" />
	<!-- Base ellipse (dome sits on floor) -->
	<ellipse cx="14" cy="15" rx="12" ry="1.6" stroke-width={Number(stroke) * 0.85} />
	<!-- Latitudinal mid-ring -->
	<line x1="4" y1="11" x2="24" y2="11" />
	<!-- Geodesic struts -->
	<line x1="8" y1="7" x2="9" y2="11" />
	<line x1="20" y1="7" x2="19" y2="11" />
	<line x1="14" y1="5" x2="9" y2="11" />
	<line x1="14" y1="5" x2="19" y2="11" />
	<line x1="14" y1="5" x2="14" y2="15" />
</svg>
